					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Celular:]]></text>
			</staticText>
			<staticText>
				<reportElement x="350" y="76" width="43" height="15"/>
				<textElement verticalAlignment="Middle">
