<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ficha_Cadastro" language="groovy" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.6105100000000028"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="738"/>
	<style name="SPC">
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{COLOR_SPC}>0]]></conditionExpression>
			<style mode="Opaque" forecolor="#FF0000"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$F{COLOR_SPC}==0]]></conditionExpression>
			<style mode="Opaque" forecolor="#009900"/>
		</conditionalStyle>
	</style>
	<parameter name="PDIR_MODELO" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["//home//mgeweb//modelos"]]></defaultValueExpression>
	</parameter>
	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["C:\\Users\\User\\Documents\\Projetos\\05 - Relatorio Formatado\\Ficha de Parceiro - Grow\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT TGFPAR.CODPARC
     , TGFPAR.NOMEPARC
     , 'Cód.Grow: ' || TGFPAR.CODPARC ||', Cód.Arte: ' || NVL(TGFPAR.CODARTE,0) || ', Cód.Uai: ' || NVL(TGFPAR.CODUAI,0) ||', Cód.Fest: ' || NVL(TGFPAR.CODFEST,0) AS CODERP
     , FORMATAR_CPF_CNPJ(TGFPAR.CGCCPF) AS CGC_CPF
     , RTRIM(LTRIM(UPPER(TGFPAR.LOGRADOURO ||' '|| TGFPAR.NUMEND || ' '|| TGFPAR.COMPLEMENTO || ' ' ||TGFPAR.BAIRRO))) AS ENDERECO
     , RTRIM(LTRIM(UPPER(TSICID.NOMECID || ' - ' || TSICID.UF))) AS CIDADE
     , TGFPAR.TELEFONE
     , TGFPAR.CELULAR
     , TGFPAR.EMAIL
     , TGFPAR.DTNASC

     , TO_CHAR(NVL(TGFPAR.DESCONTO_CONTRATO,0))AS AD_PERCONTRATODESCONTO
     , TGFPAR.DTCAD
     , (SELECT MAX(DTALTER)
        FROM(
        SELECT TRUNC(MAX(DTALTER))AS DTALTER
          FROM MOTOPRD.AD_PARLIMHIST
         WHERE CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP(TGFPAR.CODPARC)))

        UNION ALL

        SELECT TRUNC(MAX(DTALTER)) AS DTALTER
          FROM RAJAPRD.AD_PARLIMHIST
         WHERE CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP(TGFPAR.CODPARC)))

        )SUB) AS ULT_ANA_CREDITO

     ,  (SELECT TIPNEG
           FROM (

               SELECT TPV.CODTIPVENDA || ' - ' || TPV.DESCRTIPVENDA AS TIPNEG
                 FROM GROWPRD.TGFCAB CAB
               INNER JOIN GROWPRD.TGFTPV TPV ON CAB.CODTIPVENDA = TPV.CODTIPVENDA
               WHERE CAB.CODPARC = $P{CODPARC}

        )  SUB
        GROUP BY TIPNEG
        ORDER BY COUNT(1) DESC
        FETCH FIRST ROW ONLY) AS TIPNEG_1


    , (SELECT TIPOTIT
         FROM(
            SELECT TIT.CODTIPTIT || ' - ' || TIT.DESCRTIPTIT AS TIPOTIT
              FROM MOTOPRD.TGFFIN FIN
              INNER JOIN MOTOPRD.TGFTIT TIT ON FIN.CODTIPTIT = TIT.CODTIPTIT
             WHERE FIN.CODTIPOPER = 901
               AND FIN.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))

            UNION ALL

            SELECT TIT.CODTIPTIT || ' - ' || TIT.DESCRTIPTIT AS TIPOTIT
              FROM RAJAPRD.TGFFIN FIN
              INNER JOIN RAJAPRD.TGFTIT TIT ON FIN.CODTIPTIT = TIT.CODTIPTIT
             WHERE FIN.CODTIPOPER = 901
               AND FIN.CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
        )SUB
        GROUP BY TIPOTIT
        ORDER BY COUNT(1) DESC
        FETCH FIRST ROW ONLY) AS TIPOTIT_1

      , (SELECT MAX(DTNEG)
           FROM(

        SELECT MAX(DTNEG) AS DTNEG
           FROM GROWPRD.TGFCAB CAB
          WHERE CAB.CODPARC = $P{CODPARC}
            AND (CAB.NUPEDFEST IS NOT NULL OR CAB.NUPEDUAI IS NOT NULL OR CAB.NUPEDARTE IS NOT NULL)

        )SUB)  AS ULT_CONTATO
      , NULL AS PARC_MATRIZ
      , CAST(NVL(TGFPAR.LIMCREDITO,0) AS FLOAT) AS LIMCRED

      , NVL(GROWPRD.AD_GET_LIM_CRED_DISPONIVEL(TGFPAR.CODPARC),0) AS LIMITE_DISP

      , (SELECT COUNT(1)
          FROM(
              SELECT DISTINCT NURENEG
               FROM MOTOPRD.TGFFIN
              WHERE CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND NURENEG IS NOT NULL

              UNION ALL

              SELECT DISTINCT NURENEG
               FROM RAJAPRD.TGFFIN
              WHERE CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND NURENEG IS NOT NULL
          )SUB ) AS QTD_RENEG

      , CAST(NVL(
                (SELECT SUM(VLRLIQUIDO)
                   FROM(
                    SELECT SUM(VLRLIQUIDO) AS VLRLIQUIDO
                      FROM MOTOPRD.VGFFIN
                    WHERE CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND DTVENC < SYSDATE AND CODTIPTIT = 4

                    UNION ALL

                    SELECT SUM(VLRLIQUIDO) AS VLRLIQUIDO
                      FROM RAJAPRD.VGFFIN
                    WHERE CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND DTVENC < SYSDATE AND CODTIPTIT = 4

                    UNION ALL

                    SELECT SUM(VALOR) AS VLRLIQUIDO
                      FROM GROWPRD.TGFFIN
                    WHERE CODPARC = $P{CODPARC}
                      AND VENCIDO = 'S'
                      AND FORMARECEBIMENTO <> 'DINHEIRO'
                )SUB),0)AS FLOAT) TIT_EM_ATRASO

      , CAST(NVL(
                (SELECT SUM(VLRLIQUIDO)
                   FROM(
                    SELECT SUM(VLRLIQUIDO) AS VLRLIQUIDO
                      FROM MOTOPRD.VGFFIN
                      INNER JOIN MOTOPRD.TGFTIT TIT ON ( TIT.CODTIPTIT =  VGFFIN.CODTIPTIT AND AD_TIPVENDA = 1)
                    WHERE CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND DTVENC >= SYSDATE

                    UNION ALL

                    SELECT SUM(VLRLIQUIDO) AS VLRLIQUIDO
                      FROM RAJAPRD.VGFFIN
                      INNER JOIN RAJAPRD.TGFTIT TIT ON ( TIT.CODTIPTIT =  VGFFIN.CODTIPTIT AND AD_TIPVENDA = 1)
                    WHERE CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))) AND RECDESP = 1 AND DHBAIXA IS NULL AND DTVENC >= SYSDATE

                    UNION ALL

                    SELECT SUM(VALOR) AS VLRLIQUIDO
                      FROM GROWPRD.TGFFIN
                    WHERE CODPARC = $P{CODPARC}
                      AND VENCIDO = 'N'
                )SUB),0)AS FLOAT) AS TIT_EM_ABERTO
        , SPC.DET_SPC AS SPC
        , CAST(SPC.SITUACAO AS FLOAT) AS COLOR_SPC
        , SPC.OBSERVACAO AS OBS_SPC
        , CAST(nvl(GROWPRD.AD_GET_CREDITO_CLIENTE($P{CODPARC}, 9),0) AS FLOAT) AS VLRCRED_ARTE
        , CAST(nvl(GROWPRD.AD_GET_CREDITO_CLIENTE($P{CODPARC}, 1),0) AS FLOAT) AS VLRCRED_UAI
        , CAST(nvl(GROWPRD.AD_GET_CREDITO_CLIENTE($P{CODPARC}, 50),0) AS FLOAT) AS VLRCRED_FEST
        , CASE WHEN NVL(TGFPAR.SIMPLES,'N') = 'S' THEN 'Sim' ELSE 'Não' END SIMPLES
        , TGFPAR.DESCRICAOIE AS CLASSIFICMS

        , (SELECT PAR.MOTBLOQ

              FROM MOTOPRD.TGFPAR PAR
              WHERE PAR.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
                AND PAR.MOTBLOQ IS NOT NULL
                AND ROWNUM = 1
        ) AS MOTBLOQ
        , (SELECT PAR.AD_HISTORICOCREDITOMOTOFEST

              FROM MOTOPRD.TGFPAR PAR
              WHERE PAR.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
                AND PAR.AD_HISTORICOCREDITOMOTOFEST IS NOT NULL
                AND ROWNUM = 1
        ) AS HIST_FEST
        , NVL((SELECT SUM(VLRDESDOB)
              FROM(
                    SELECT FIN.VLRDESDOB
                      FROM MOTOPRD.TGFFIN FIN
                     WHERE (FIN.CODCTABCOINT = 27)
                       AND (FIN.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
                       AND (FIN.RECDESP = 1)

                    UNION ALL

                    SELECT FIN.VLRDESDOB
                      FROM RAJAPRD.TGFFIN FIN
                     WHERE (FIN.CODCTABCOINT = 71)
                       AND (FIN.CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
                       AND (FIN.RECDESP = 1)
            )SUB ),0) AS VLR_PCLD
          , CAST(NVL((SELECT COUNT(1) FROM GROWPRD.PARCTT CTT WHERE CTT.CODPARC = TGFPAR.CODPARC),0) AS FLOAT) QTD_CTT



          , ROUND(NVL (
               (SELECT AVG (GREATEST (NVL (DHBAIXA, SYSDATE) - DTVENC, 0))
                  FROM(

                  SELECT F.DHBAIXA
                        ,F.DTVENC
                  FROM MOTOPRD.TGFFIN F
                 WHERE F.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
                       AND F.CODTIPTIT = 4
                       AND F.PROVISAO = 'N'
                       AND F.RECDESP = 1
                       AND F.DTVENC >= SYSDATE - 180

                UNION ALL

                  SELECT F.DHBAIXA
                        ,F.DTVENC
                  FROM RAJAPRD.TGFFIN F
                 WHERE     F.CODPARC IN (SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
                       AND F.CODTIPTIT = 4
                       AND F.PROVISAO = 'N'
                       AND F.RECDESP = 1
                       AND F.DTVENC >= SYSDATE - 180

                  UNION ALL

                       SELECT NULL AS DHBAIXA
                            , F.DTVENC
                         FROM GROWPRD.TGFFIN F
                         WHERE F.CODPARC = $P{CODPARC}
                           AND F.DTVENC >= SYSDATE - 180


                  UNION ALL

                       SELECT F.DTMOV AS DHBAIXA
                            , F.DTVENC
                         FROM MOTOPRD.AD_FESTFIN_RECEBIDO F
                         WHERE F.CODPARC IN (SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC})))
                           AND F.DTVENC >= SYSDATE - 180



            )SUB), 0),2)
               AS ATR_MEDIO_DIAS

    FROM GROWPRD.TGFPAR
   LEFT JOIN GROWPRD.TSICID ON TSICID.CODCID = TGFPAR.CODCID
   OUTER APPLY (SELECT DECODE(SUB.SITUACAO,'1','Com Pendências','0', 'Sem Pendências','2','Com Pend. Desconsideradas') || CASE WHEN SUB.SITUACAO = '1' THEN   ' - Data: ' || DATA || ', Qtd.: ' || NVL(SUB.QTDPENDENCIA,0) || ', Vlr.: R$ ' || NVL(SUB.VLRPENDENCIA,0)  ELSE '. Data Últ. Consulta: ' || TO_CHAR(DATA,'DD/MM/YYYY') END AS DET_SPC
             , SITUACAO
             , OBSERVACAO
             , CODPARC
            FROM (
                  SELECT DATA, SITUACAO,QTDPENDENCIA, VLRPENDENCIA , OBSERVACAO, NVL(CTT.CODPARC,PAR.CODPARC) AS CODPARC
                   FROM MOTOPRD.AD_TGFSPC SPC
                   LEFT JOIN GROWPRD.TGFPAR PAR ON PAR.CODARTE = SPC.CODPARC
                   LEFT JOIN GROWPRD.PARCTT CTT ON CTT.CODARTE = SPC.CODPARC
                   WHERE NVL(CTT.CODPARC,PAR.CODPARC) = $P{CODPARC}



                   UNION ALL

                  SELECT DATA, SITUACAO,QTDPENDENCIA, VLRPENDENCIA , OBSERVACAO, NVL(CTT.CODPARC,PAR.CODPARC) AS CODPARC
                   FROM RAJAPRD.AD_TGFSPC SPC
                   LEFT JOIN GROWPRD.TGFPAR PAR ON PAR.CODARTE = SPC.CODPARC
                   LEFT JOIN GROWPRD.PARCTT CTT ON CTT.CODARTE = SPC.CODPARC
                   WHERE NVL(CTT.CODPARC,PAR.CODPARC) = $P{CODPARC}


          )SUB

          GROUP BY DECODE(SUB.SITUACAO,'1','Com Pendências','0', 'Sem Pendências','2','Com Pend. Desconsideradas') || CASE WHEN SUB.SITUACAO = '1' THEN   ' - Data: ' || DATA || ', Qtd.: ' || NVL(SUB.QTDPENDENCIA,0) || ', Vlr.: R$ ' || NVL(SUB.VLRPENDENCIA,0)  ELSE '. Data Últ. Consulta: ' || TO_CHAR(DATA,'DD/MM/YYYY') END
                , SITUACAO
                , OBSERVACAO
                , CODPARC
          ORDER BY MAX(DATA) DESC
          FETCH FIRST ROW ONLY
          ) SPC



 WHERE TGFPAR.CODPARC = $P{CODPARC}]]>
	</queryString>
	<field name="CODPARC" class="java.math.BigDecimal"/>
	<field name="NOMEPARC" class="java.lang.String"/>
	<field name="CODERP" class="java.lang.String"/>
	<field name="CGC_CPF" class="java.lang.String"/>
	<field name="ENDERECO" class="java.lang.String"/>
	<field name="CIDADE" class="java.lang.String"/>
	<field name="TELEFONE" class="java.lang.String"/>
	<field name="CELULAR" class="java.lang.String"/>
	<field name="EMAIL" class="java.lang.String"/>
	<field name="DTNASC" class="java.sql.Timestamp"/>
	<field name="AD_PERCONTRATODESCONTO" class="java.lang.String"/>
	<field name="DTCAD" class="java.sql.Timestamp"/>
	<field name="ULT_ANA_CREDITO" class="java.sql.Timestamp"/>
	<field name="TIPNEG_1" class="java.lang.String"/>
	<field name="TIPOTIT_1" class="java.lang.String"/>
	<field name="ULT_CONTATO" class="java.sql.Timestamp"/>
	<field name="PARC_MATRIZ" class="java.lang.String"/>
	<field name="LIMCRED" class="java.lang.Double"/>
	<field name="LIMITE_DISP" class="java.math.BigDecimal"/>
	<field name="QTD_RENEG" class="java.math.BigDecimal"/>
	<field name="TIT_EM_ATRASO" class="java.lang.Double"/>
	<field name="TIT_EM_ABERTO" class="java.lang.Double"/>
	<field name="SPC" class="java.lang.String"/>
	<field name="COLOR_SPC" class="java.lang.Double"/>
	<field name="OBS_SPC" class="java.lang.String"/>
	<field name="VLRCRED_ARTE" class="java.lang.Double"/>
	<field name="VLRCRED_UAI" class="java.lang.Double"/>
	<field name="VLRCRED_FEST" class="java.lang.Double"/>
	<field name="SIMPLES" class="java.lang.String"/>
	<field name="CLASSIFICMS" class="java.lang.String"/>
	<field name="MOTBLOQ" class="java.lang.String"/>
	<field name="HIST_FEST" class="java.lang.String"/>
	<field name="VLR_PCLD" class="java.math.BigDecimal"/>
	<field name="QTD_CTT" class="java.lang.Double"/>
	<field name="ATR_MEDIO_DIAS" class="java.math.BigDecimal"/>
	<variable name="TOT_TIT_ABERTO" class="java.lang.Double">
		<variableExpression><![CDATA[$F{TIT_EM_ATRASO} + $F{TIT_EM_ABERTO}]]></variableExpression>
	</variable>
