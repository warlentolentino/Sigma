	<property name="ireport.zoom" value="1.2100000000000029"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT CTT.CODPARC
     , CTT.CODCTT
     , CTT.CGCCPF
     , CTT.NOMEPARC
     , CTT.CODARTE
     , CTT.CODUAI
     , CTT.CODFEST
     , CASE WHEN NVL(CTT.SIMPLES,'N') = 'S' THEN 'Sim' ELSE 'Não' END AS SIMPLES_GROW
     , CASE WHEN NVL(P2.SIMPLES,'N') = 'S' THEN 'Sim' ELSE 'Não' END AS SIMPLES_ARTE
     , CASE WHEN NVL(P3.SIMPLES,'N') = 'S' THEN 'Sim' ELSE 'Não' END AS SIMPLES_UAI
  FROM GROWPRD.PARCTT CTT
   LEFT JOIN MOTOPRD.TGFPAR P2 ON P2.CODPARC = CTT.CODARTE
   LEFT JOIN RAJAPRD.TGFPAR P3 ON P3.CODPARC = CTT.CODUAI
  WHERE CTT.CODPARC = $P{CODPARC}
ORDER BY CTT.CODCTT]]>
	</queryString>
	<field name="CODPARC" class="java.math.BigDecimal"/>
	<field name="CODCTT" class="java.math.BigDecimal"/>
	<field name="CGCCPF" class="java.lang.String"/>
	<field name="NOMEPARC" class="java.lang.String"/>
