<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ficha_credito_grow" language="groovy" pageWidth="555" pageHeight="100" whenNoDataType="AllSectionsNoDetail" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" isIgnorePagination="true">
	<property name="ireport.zoom" value="1.331000000000001"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT '9 - MOTO ARTE' AS EMPRESA
        , PAR.CODPARC
        , PAR.NOMEPARC
        , FIN.DTNEG
        , FIN.VLRLIQUIDO
   FROM MOTOPRD.VGFFIN FIN
   INNER JOIN MOTOPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
  WHERE FIN.CODTIPTIT = 52
   AND FIN.RECDESP = -1
   AND FIN.DHBAIXA IS NULL
   AND FIN.CODEMP = 9
   AND FIN.CODPARC IN ((SELECT CODARTE FROM TABLE(AD_GET_PARCEIROS_ERP($P{CODPARC}))))

UNION ALL

  SELECT '1 - MOTO UAI' AS EMPRESA
        , PAR.CODPARC
        , PAR.NOMEPARC
        , FIN.DTNEG
        , FIN.VLRLIQUIDO
   FROM RAJAPRD.VGFFIN FIN
   INNER JOIN RAJAPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
  WHERE FIN.CODTIPTIT = 52
   AND FIN.RECDESP = -1
   AND FIN.DHBAIXA IS NULL
   AND FIN.CODEMP = 1
   AND FIN.CODPARC IN ((SELECT CODUAI FROM TABLE(AD_GET_PARCEIROS_ERP($P{CODPARC}))))


UNION ALL

  SELECT '50 - MOTO FEST' AS EMPRESA
        , PAR.CODFEST AS CODPARC
        , PAR.NOMEPARC
        , FIN.DTNEG
        , FIN.VALOR AS VLRLIQUIDO
      FROM GROWPRD.TGFFIN FIN
      INNER JOIN GROWPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
      WHERE FIN.CREDCLIENTE = 'S'
        AND FIN.CODPARC = $P{CODPARC}
        AND NVL(FIN.CONTABANCARIA,' ') <> 'MATRIZ - CAIXA  AUXILIAR'
ORDER BY 1,4]]>
	</queryString>
	<field name="EMPRESA" class="java.lang.String"/>
	<field name="CODPARC" class="java.math.BigDecimal"/>
	<field name="NOMEPARC" class="java.lang.String"/>
	<field name="DTNEG" class="java.sql.Timestamp"/>
	<field name="VLRLIQUIDO" class="java.lang.Double"/>
