	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[WITH SUB2 AS (
SELECT *
  FROM(
    SELECT  'MOTO ARTE' AS EMPRESA
          , 9 AS CODEMP
          , TGFCAB.NUNOTA
          , TGFCAB.DTNEG
          , TGFCAB.NUMNOTA
          , TGFTPV.CODTIPVENDA || ' - ' || TGFTPV.DESCRTIPVENDA AS TIPO_NEG
          , TGFCAB.VLRNOTA
          , TGFVEN.CODVEND || ' - ' || TGFVEN.APELIDO AS VENDEDOR
       FROM MOTOPRD.TGFCAB
       INNER JOIN MOTOPRD.TGFTPV ON TGFTPV.CODTIPVENDA = TGFCAB.CODTIPVENDA AND TGFCAB.DHTIPVENDA = TGFTPV.DHALTER
       INNER JOIN MOTOPRD.TGFVEN ON TGFVEN.CODVEND = TGFCAB.CODVEND
      WHERE TGFCAB.CODTIPOPER = 901
        AND TGFCAB.CODPARC IN((SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
        AND TGFCAB.STATUSNOTA = 'L'


    UNION ALL

    SELECT  'MOTO UAI' AS EMPRESA
          , 1 AS CODEMP
          , TGFCAB.NUNOTA
          , TGFCAB.DTNEG
          , TGFCAB.NUMNOTA
          , TGFTPV.CODTIPVENDA || ' - ' || TGFTPV.DESCRTIPVENDA AS TIPO_NEG
          , TGFCAB.VLRNOTA
          , TGFVEN.CODVEND || ' - ' || TGFVEN.APELIDO AS VENDEDOR
       FROM RAJAPRD.TGFCAB
       INNER JOIN RAJAPRD.TGFTPV ON TGFTPV.CODTIPVENDA = TGFCAB.CODTIPVENDA AND TGFCAB.DHTIPVENDA = TGFTPV.DHALTER
       INNER JOIN RAJAPRD.TGFVEN ON TGFVEN.CODVEND = TGFCAB.CODVEND
      WHERE TGFCAB.CODTIPOPER = 901
        AND TGFCAB.CODPARC IN((SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
        AND TGFCAB.STATUSNOTA = 'L'


    UNION ALL

    SELECT 'MOTO FEST' AS EMPRESA
         , 50 AS CODEMP
          , TGFCAB.NUNOTA
          , TGFCAB.DTNEG
          , TGFCAB.NUPEDFEST AS NUMNOTA
          , TGFTPV.CODTIPVENDA || ' - ' || TGFTPV.DESCRTIPVENDA AS TIPO_NEG
          , TGFCAB.VLRNOTA
          , TSIUSU.CODUSU || ' - ' || TSIUSU.NOMEUSU AS VENDEDOR
      FROM GROWPRD.TGFCAB
      INNER JOIN GROWPRD.TGFTPV ON TGFTPV.CODTIPVENDA = TGFCAB.CODTIPVENDA
      INNER JOIN GROWPRD.TSIUSU ON TSIUSU.CODUSU = TGFCAB.CODUSUVEND
      WHERE NUPEDFEST IS NOT NULL
        AND CODEMP = 50
        AND CODPARC = $P{CODPARC}
)SUB
ORDER BY DTNEG DESC
FETCH NEXT 10 ROWS ONLY
)
SELECT SUB2.EMPRESA
     , SUB2.NUNOTA
     , SUB2.DTNEG
     , SUB2.NUMNOTA
     , SUB2.TIPO_NEG
     , SUB2.VLRNOTA
     , SUB2.VENDEDOR
     , TGFPRO.CODPROD || ' - ' || TGFPRO.DESCRPROD AS PRODUTO
     , CAST(TGFITE.QTDNEG AS INT) AS QTDNEG
     , TGFITE.VLRUNIT
     , TGFITE.VLRTOT
     , TGFITE.VLRDESC
     , TGFITE.VLRTOT - TGFITE.VLRDESC AS VLRLIQ
  FROM SUB2
  INNER JOIN MOTOPRD.TGFITE ON TGFITE.NUNOTA = SUB2.NUNOTA
  INNER JOIN MOTOPRD.TGFPRO ON TGFPRO.CODPROD = TGFITE.CODPROD
 WHERE SUB2.CODEMP = 9

UNION ALL

SELECT SUB2.EMPRESA
     , SUB2.NUNOTA
     , SUB2.DTNEG
     , SUB2.NUMNOTA
     , SUB2.TIPO_NEG
     , SUB2.VLRNOTA
     , SUB2.VENDEDOR
     , TGFPRO.CODPROD || ' - ' || TGFPRO.DESCRPROD AS PRODUTO
     , CAST(TGFITE.QTDNEG AS INT) AS QTDNEG
     , TGFITE.VLRUNIT
     , TGFITE.VLRTOT
     , TGFITE.VLRDESC
     , TGFITE.VLRTOT - TGFITE.VLRDESC AS VLRLIQ
  FROM SUB2
  INNER JOIN RAJAPRD.TGFITE ON TGFITE.NUNOTA = SUB2.NUNOTA
  INNER JOIN RAJAPRD.TGFPRO ON TGFPRO.CODPROD = TGFITE.CODPROD
 WHERE SUB2.CODEMP = 1

UNION ALL

SELECT SUB2.EMPRESA
     , SUB2.NUNOTA
     , SUB2.DTNEG
     , SUB2.NUMNOTA
     , SUB2.TIPO_NEG
     , SUB2.VLRNOTA
     , SUB2.VENDEDOR
     , TGFPRO.CODPROD || ' - ' || TGFPRO.DESCRPROD AS PRODUTO
     , CAST(TGFITE.QTDNEG AS INT) AS QTDNEG
     , TGFITE.VLRUNIT
     , TGFITE.VLRTOT
     , TGFITE.VLRDESC
     , TGFITE.VLRTOT - TGFITE.VLRDESC AS VLRLIQ
  FROM SUB2
  INNER JOIN GROWPRD.TGFITE ON TGFITE.NUNOTA = SUB2.NUNOTA
  INNER JOIN GROWPRD.TGFPRO ON TGFPRO.CODPROD = TGFITE.CODPROD
 WHERE SUB2.CODEMP = 50
 ORDER BY EMPRESA, DTNEG DESC]]>
	</queryString>
