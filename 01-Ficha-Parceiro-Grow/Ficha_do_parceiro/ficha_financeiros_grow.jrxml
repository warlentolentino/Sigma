	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT EMP.CODEMP || ' - ' || EMP.NOMEFANTASIA AS EMPRESA
     , PAR.CODPARC || ' - ' || PAR.NOMEPARC AS NOMEPARC
     , TO_CHAR(FIN.NUMNOTA) AS NUMNOTA
     , FIN.DTNEG
     , FIN.DTVENC
     , FIN.VLRDESDOB
     , CAST(CASE WHEN TRUNC(FIN.DTVENC) < TRUNC(SYSDATE) THEN 1 ELSE 0 END AS FLOAT) VENCIDO
  FROM MOTOPRD.VGFFIN FIN
  INNER JOIN MOTOPRD.TSIEMP EMP ON EMP.CODEMP = FIN.CODEMP
  INNER JOIN MOTOPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
WHERE FIN.CODPARC IN ((SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
  AND FIN.RECDESP = 1
  AND FIN.DHBAIXA IS NULL
  AND FIN.CODTIPTIT = 4
  AND FIN.CODTIPOPER = 901

UNION ALL

SELECT EMP.CODEMP || ' - ' || EMP.NOMEFANTASIA AS EMPRESA
     , PAR.CODPARC || ' - ' || PAR.NOMEPARC AS NOMEPARC
     , TO_CHAR(FIN.NUMNOTA) AS NUMNOTA
     , FIN.DTNEG
     , FIN.DTVENC
     , FIN.VLRDESDOB
     , CAST(CASE WHEN TRUNC(FIN.DTVENC) < TRUNC(SYSDATE) THEN 1 ELSE 0 END AS FLOAT) VENCIDO
  FROM RAJAPRD.VGFFIN FIN
  INNER JOIN RAJAPRD.TSIEMP EMP ON EMP.CODEMP = FIN.CODEMP
  INNER JOIN RAJAPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
WHERE FIN.CODPARC IN ((SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
  AND FIN.RECDESP = 1
  AND FIN.DHBAIXA IS NULL
  AND FIN.CODTIPTIT = 4
  AND FIN.CODTIPOPER = 901

UNION ALL

SELECT '50 - MOTO FEST' AS EMPRESA
     , CASE WHEN CTT.CODCTT IS NULL THEN PAR.CODFEST || ' - ' || PAR.NOMEPARC ELSE CTT.CODFEST || ' - ' || CTT.NOMEPARC END AS NOMEPARC
     , FIN.NUMDOC AS NUMNOTA
     , FIN.DTNEG
     , FIN.DTVENC
     , FIN.VALOR AS VLRDESDOB
     , CAST(CASE WHEN TRUNC(FIN.DTVENC) < TRUNC(SYSDATE) THEN 1 ELSE 0 END AS FLOAT) VENCIDO
  FROM GROWPRD.TGFFIN FIN
  INNER JOIN GROWPRD.TGFPAR PAR ON PAR.CODPARC = FIN.CODPARC
   LEFT JOIN GROWPRD.PARCTT CTT ON CTT.CODPARC = FIN.CODPARC AND CTT.CODCTT = FIN.CODCTT
  WHERE FIN.CODPARC = $P{CODPARC}
    AND FIN.CREDCLIENTE = 'N'
    AND NVL(FIN.FORMARECEBIMENTO,'BOLETO')  = 'BOLETO'

ORDER BY 5,2]]>
	</queryString>
	<field name="EMPRESA" class="java.lang.String"/>
	<field name="NOMEPARC" class="java.lang.String"/>
	<field name="NUMNOTA" class="java.lang.String"/>
	<field name="DTNEG" class="java.sql.Timestamp"/>
	<field name="DTVENC" class="java.sql.Timestamp"/>
	<field name="VLRDESDOB" class="java.lang.Double"/>
	<field name="VENCIDO" class="java.lang.Double"/>
