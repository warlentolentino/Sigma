						<font size="8" isBold="true"/>
					</textElement>
					<text><![CDATA[Ult. Vlr. Compra]]></text>
				</staticText>
				<textField>
					<reportElement mode="Opaque" x="0" y="0" width="355" height="13" backcolor="#CCCCCC"/>
					<box leftPadding="0">
						<topPen lineWidth="0.5"/>
						<leftPen lineWidth="0.5"/>
						<bottomPen lineWidth="0.5"/>
