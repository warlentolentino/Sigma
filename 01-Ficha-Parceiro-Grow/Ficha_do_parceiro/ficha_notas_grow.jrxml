<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ficha_notas_grow" language="groovy" pageWidth="200" pageHeight="345" whenNoDataType="AllSectionsNoDetail" columnWidth="200" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
	<property name="ireport.zoom" value="2.5937424601000028"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<style name="zebra">
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{COLUMN_COUNT}%2==0]]></conditionExpression>
			<style mode="Opaque" backcolor="#FFFFFF"/>
		</conditionalStyle>
		<conditionalStyle>
			<conditionExpression><![CDATA[$V{COLUMN_COUNT}%2!=0]]></conditionExpression>
			<style mode="Opaque" backcolor="#CCCCCC"/>
		</conditionalStyle>
	</style>
	<parameter name="CODPARC" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Cód. Parceiro]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[
SELECT *
  FROM(
SELECT *
  FROM(
    SELECT  'MOTO ARTE' AS EMPRESA
          , TGFCAB.DTNEG
          , TGFCAB.NUMNOTA
          , TGFCAB.VLRNOTA
       FROM MOTOPRD.TGFCAB
      WHERE TGFCAB.CODTIPOPER = 901
        AND TGFCAB.CODPARC IN((SELECT CODARTE FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
        AND TGFCAB.STATUSNOTA = 'L'



    UNION ALL

    SELECT  'MOTO UAI' AS EMPRESA
          , TGFCAB.DTNEG
          , TGFCAB.NUMNOTA
          , TGFCAB.VLRNOTA
       FROM RAJAPRD.TGFCAB
      WHERE TGFCAB.CODTIPOPER = 901
        AND TGFCAB.CODPARC IN((SELECT CODUAI FROM TABLE(GROWPRD.AD_GET_PARCEIROS_ERP($P{CODPARC}))))
        AND TGFCAB.STATUSNOTA = 'L'


    UNION ALL

    SELECT 'MOTO FEST' AS EMPRESA
         , FEST.DTNEG
         , FEST.NUMNOTA AS NUMNOTA
         , SUM(FEST.VLRTOT) AS VLRNOTA
  FROM GROWPRD.FATFEST FEST
  WHERE CODPARC = $P{CODPARC}
  GROUP BY FEST.DTNEG
         , FEST.NUMNOTA

)SUB
ORDER BY DTNEG DESC
FETCH NEXT 20 ROWS ONLY
)SUB2
ORDER BY EMPRESA, DTNEG DESC]]>
	</queryString>
	<field name="EMPRESA" class="java.lang.String"/>
	<field name="DTNEG" class="java.sql.Timestamp"/>
	<field name="NUMNOTA" class="java.math.BigDecimal"/>
	<field name="VLRNOTA" class="java.math.BigDecimal"/>
